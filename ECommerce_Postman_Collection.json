{
  "info": {
    "name": "E-Commerce API",
    "description": "Postman Collection for E-Commerce Backend. Includes User, Product, Post, and Order APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. User API",
      "item": [
        {
          "name": "Sign-up",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"123456\",\n  \"confirmPassword\": \"123456\",\n  \"phone\": \"0123456789\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/sign-up",
              "host": ["{{baseUrl}}"],
              "path": ["user", "sign-up"]
            }
          }
        },
        {
          "name": "Sign-in (Auto Set Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.access_token) {",
                  "    pm.collectionVariables.set(\"access_token\", jsonData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/sign-in",
              "host": ["{{baseUrl}}"],
              "path": ["user", "sign-in"]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "token", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/getAll",
              "host": ["{{baseUrl}}"],
              "path": ["user", "getAll"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Product API",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/product/get-all?limit=10&page=0",
              "host": ["{{baseUrl}}"],
              "path": ["product", "get-all"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "page", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nhẫn Bạc Nam\",\n  \"image\": \"base64_string_here\",\n  \"type\": \"Nhẫn\",\n  \"category\": \"Trang sức nam\",\n  \"material\": \"Bạc S925\",\n  \"countInStock\": 100,\n  \"price\": 500000,\n  \"rating\": 5,\n  \"description\": \"Nhẫn bạc cao cấp\",\n  \"discount\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/product/create",
              "host": ["{{baseUrl}}"],
              "path": ["product", "create"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Post API",
      "item": [
        {
          "name": "Get All Posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/post/get-all",
              "host": ["{{baseUrl}}"],
              "path": ["post", "get-all"]
            }
          }
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "token", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bài viết mẫu 1\",\n  \"image\": \"base64_image\",\n  \"content\": \"Nội dung bài viết mẫu\",\n  \"type\": \"Tin tức\",\n  \"author\": \"Jensy\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/post/create",
              "host": ["{{baseUrl}}"],
              "path": ["post", "create"]
            }
          }
        }
      ]
    }
  ]
}
