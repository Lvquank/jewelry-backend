PORT=3001
MongoDB=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/ecommerce?retryWrites=true&w=majority
ACCESS_TOKEN=your_access_token_secret
REFRESH_TOKEN=your_refresh_token_secret

